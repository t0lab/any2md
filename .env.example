# Copy to `.env` and fill in. `.env` is gitignored.
# scripts/run_agent.py auto-loads this file via python-dotenv.

# === LiteLLM proxy (default text_model for local dev) ===
LITELLM_API_KEY=
LITELLM_BASE_URL=https://litellm-horseai.everlearners.io/v1
LITELLM_MODEL=openai/Qwen/Qwen3.6-35B-A3B

# === Databricks (when running on / against a workspace) ===
# DATABRICKS_HOST=https://<workspace>.databricks.com
# DATABRICKS_TOKEN=

# === Provider overrides (only if you switch ModelConfig away from LiteLLM) ===
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# === LangSmith observability (optional but recommended for debugging agent runs) ===
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT="any2md"
